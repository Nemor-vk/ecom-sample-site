generator client {
  provider   = "prisma-client-js"
  // binaryTargets = ["native", "debian-openssl-3.0.x"] // native for local dev, debian-openssl-3.0.x for Vercel
  engineType = "client"
  output     = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id             String             @id @default(uuid())
  userId         String
  labelPreset    AddressLabelPreset @default(Home)
  customLabel    String?
  primaryAddress String
  streetAddress  String
  city           String
  state          String
  landmark       String?
  pincode        String
  phoneNumber    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  recipientName  String?
  user           User               @relation(fields: [userId], references: [id])
}

model Category {
  id            String     @id @default(uuid())
  name          String     @unique
  description   String?
  imageUrl      String?
  parentId      String?
  isActive      Boolean?
  productCount  Int?
  discountId    String?
  discount      Discount?  @relation(fields: [discountId], references: [id])
  parent        Category?  @relation("Subcategories", fields: [parentId], references: [id])
  subcategories Category[] @relation("Subcategories")
  products      Product[]
  sections      Section[]  @relation("CategoryToSection")
}

model Discount {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String
  description       String?
  type              DiscountType
  value             Float
  minOrderAmount    Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usedCount         Int               @default(0)
  isActive          Boolean           @default(true)
  validFrom         DateTime
  validUntil        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  usageLimitPeriod  UsageLimitPeriod?
  categories        Category[]
  orders            Order[]
  products          Product[]
}

model Image {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  productId String?
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  status       OrderStatus @default(PENDING)
  userId       String
  discountId   String?
  paymentTotal Decimal     @db.Decimal(10, 2)
  discount     Discount?   @relation(fields: [discountId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int     @default(1)
  amountPaid Decimal @db.Decimal(10, 2)
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
}

model Product {
  id                   String      @id @default(uuid())
  name                 String      @unique
  description          String?
  price                Decimal     @db.Decimal(10, 2)
  stock                Int         @default(0)
  productType          ProductType @default(PHYSICAL)
  rating               Int         @default(0)
  filePath             String?
  downloadUrl          String?
  productTags          String[]
  availableForPurchase Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  categoryId           String
  discountId           String?
  originalPrice        Decimal?    @db.Decimal(10, 2)
  image                Image[]
  orderItems           OrderItem[]
  category             Category    @relation(fields: [categoryId], references: [id])
  discount             Discount?   @relation(fields: [discountId], references: [id])
  sections             Section[]   @relation("ProductToSection")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String  @id @default(uuid())
  action      String
  resource    String
  description String?
  roles       Role[]  @relation("RolePermissions")
}

model Section {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  imageUrl    String?
  isActive    Boolean?
  category    Category[] @relation("CategoryToSection")
  products    Product[]  @relation("ProductToSection")
}

model User {
  id           String    @id @default(uuid())
  fullName     String
  email        String    @unique
  password     String
  profileImage String?
  dateOfBirth  DateTime
  mobileNumber String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  gender       Gender?
  roleId       String
  Address      Address[]
  Order        Order[]
  role         Role      @relation("UserRoles", fields: [roleId], references: [id])
}

model ApiKey {
  id               String   @id @default(cuid())
  label            String
  hashedKey        String   @unique
  active           Boolean  @default(true)
  rateLimit        Int      @default(1000)
  allowedDomains   String[] @default([])
  allowedIPs       String[] @default([])
  allowedReferrers String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  logs             ApiLog[]
}

model ApiLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  ip        String
  origin    String
  referrer  String
  path      String
  timestamp DateTime @default(now())
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
}

model RateLimit {
  key   String @id
  count Int
}

enum AddressLabelPreset {
  Home
  Work
  Hotel
  Others
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum UsageLimitPeriod {
  LIFETIME
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
  PROCESSING
  SHIPPED
  RETURNED
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum Gender {
  Male
  Female
}
